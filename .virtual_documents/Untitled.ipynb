import numpy as np

class GrdRegressor:
    def __init__(self, learning_rate=0.01, epochs=1000):
        self.intercept_ = None
        self.coef_ = None
        self.lr = learning_rate
        self.epochs = epochs

    def fit(self, X_train, y_train):
        # Ensure input is numpy and 1D/2D correctly
        X_train = np.asarray(X_train)
        y_train = np.asarray(y_train).ravel() 
        
        m, n = X_train.shape
        
        # Initialize weights OUTSIDE the loop
        self.intercept_ = 0
        self.coef_ = np.zeros(n)
        
        for _ in range(self.epochs):
            # 1. Prediction (y_hat)
            y_hat = (X_train @ self.coef_) + self.intercept_
            
            # 2. Calculate the difference (Residuals)
            error = y_hat - y_train
            
            # 3. Gradients using np.sum instead of np.mean
            # Derivative w.r.t intercept (bias)
            dj_db = np.sum(error) / m
            
            # Derivative w.r.t weights (coef)
            # (X.T @ error) already performs a sum-product
            dj_dw = (X_train.T @ error) / m
            
            # 4. Update Parameters
            self.intercept_ -= (self.lr * dj_db)
            self.coef_ -= (self.lr * dj_dw)

    def predict(self, X_test):
        X_test = np.asarray(X_test)
        return (X_test @ self.coef_) + self.intercept_


